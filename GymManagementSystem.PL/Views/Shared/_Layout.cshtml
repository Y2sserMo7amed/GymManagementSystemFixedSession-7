<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+Thambi+2:wght@400..800&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <title>Power Fitness | @ViewData["Title"]</title>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-white my-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.jpg" alt="Logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">

                    @* Only show navigation links if the user is logged in *@
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Member" asp-action="Index">Members</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Trainer" asp-action="Index">Trainers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Plan" asp-action="Index">Plans</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 mx-2 fw-bolder fs-5" asp-controller="Analytics" asp-action="Index">Analytics</a>
                            </li>
                        </ul>

                        @* Logout button — only visible when logged in *@
                        <div class="d-flex align-items-center gap-3 ms-auto">
                            <span class="text-muted small">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </span>
                            <form asp-action="Logout" asp-controller="Account" method="post">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
