@model PlanEditViewModel
@{ ViewData["Title"] = "Edit Plan"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary-color text-white text-center py-4">
                    <h3 class="mb-0">Edit Plan</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="Id" type="hidden" />
                        <input asp-for="Name" type="hidden" />

                        <div class="mb-4">
                            <div class="p-3 bg-light rounded">
                                <small class="text-muted d-block mb-1">Plan Name <span class="badge bg-secondary">Locked</span></small>
                                <strong class="fs-5">@Model.Name</strong>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DurationDays" class="form-label fw-medium">Duration (days) <span class="text-danger">*</span></label>
                            <input asp-for="DurationDays" class="form-control" type="number" min="1" />
                            <span asp-validation-for="DurationDays" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-medium">Price (EGP) <span class="text-danger">*</span></label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-medium">Description <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </a>
                            <button type="submit" class="btn btn-fill flex-fill">
                                <i class="bi bi-floppy me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
