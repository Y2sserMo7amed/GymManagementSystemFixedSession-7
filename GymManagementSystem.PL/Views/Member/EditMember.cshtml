@model EditMemberViewModel
@{ ViewData["Title"] = "Edit Member"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-details border-0 p-2 shadow">
                <div class="card-body text-center">
                    <div class="text-center mt-3">
                        <img src="~/images/@(Model.Photo ?? "icon.jpg")" alt="@Model.Name"
                             class="rounded-circle"
                             style="width:120px;height:120px;object-fit:cover;border:3px solid #fff;margin-top:-60px;" />
                    </div>

                    <h2 class="mb-1 text-primary-color">@Model.Name</h2>

                    <form asp-action="EditMember" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="Id" type="hidden" />
                        <input asp-for="Name" type="hidden" />
                        <input asp-for="Photo" type="hidden" />

                        <div class="mt-4 text-start">
                            <div class="row g-3">
                                <div class="col-12">
                                    <div class="p-3 bg-light rounded">
                                        <small class="text-muted d-block mb-1">Email</small>
                                        <input asp-for="Email" class="form-control" />
                                        <span asp-validation-for="Email" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded">
                                        <small class="text-muted d-block mb-1">Phone</small>
                                        <input asp-for="Phone" class="form-control" />
                                        <span asp-validation-for="Phone" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded">
                                        <small class="text-muted d-block mb-1">Building Number</small>
                                        <input asp-for="BuildingNumber" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded">
                                        <small class="text-muted d-block mb-1">City</small>
                                        <input asp-for="City" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded">
                                        <small class="text-muted d-block mb-1">Street</small>
                                        <input asp-for="Street" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between gap-2 mt-3 px-3 pb-3">
                            <a asp-action="Index" class="btn btn-fill">Back to List</a>
                            <button type="submit" class="btn btn-fill">Done</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
