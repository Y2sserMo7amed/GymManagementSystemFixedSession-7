@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="text-primary-color">Welcome to Power Fitness</h1>
    <p class="text-muted fs-5">Manage your gym efficiently</p>
    <div class="d-flex gap-3 justify-content-center mt-4">
        <a asp-controller="Member" asp-action="Index" class="btn btn-fill px-4 py-2">Members</a>
        <a asp-controller="Trainer" asp-action="Index" class="btn btn-fill px-4 py-2">Trainers</a>
        <a asp-controller="Plan" asp-action="Index" class="btn btn-fill px-4 py-2">Plans</a>
    </div>
</div>
